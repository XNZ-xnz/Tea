@@ -822,8 +822,15 @@ void SpirvBuilder::emitDclLds(const ir::Op& op) {
   auto typeId = getIdForType(op.getType());
   auto ptrTypeId = getIdForPtrType(typeId, spv::StorageClassWorkgroup);
 
+  // Tea/MoltenVK: do NOT zero-initialize workgroup memory via a variable
+  // initializer. Metal threadgroup memory cannot have initializers, so
+  // SPIRV-Cross (as bundled in MoltenVK 1.4.2) emulates it with generated
+  // zero-fill code that references gl_WorkGroupSize without declaring it,
+  // failing MSL compilation for every compute shader that uses groupshared
+  // memory. D3D11 does not guarantee zeroed groupshared memory anyway
+  // (scratch is left uninitialized for the same reason, see below).
   pushOp(m_declarations, spv::OpVariable, ptrTypeId, varId,
-    spv::StorageClassWorkgroup, getIdForConstantNull(op.getType()));
+    spv::StorageClassWorkgroup);
 
   addEntryPointId(varId);
 }
@@ -2487,7 +2494,14 @@ void SpirvBuilder::emitAtomic(const ir::Op& op, const ir::Type& type, uint32_t i
   auto [opCode, argCount] = [&] {
     switch (atomicOp) {
       case ir::AtomicOp::eLoad:             return std::make_pair(spv::OpAtomicLoad, 0u);
-      case ir::AtomicOp::eStore:            return std::make_pair(spv::OpAtomicStore, 1u);
+      // Tea/MoltenVK: emit atomic stores as OpAtomicExchange with a discarded
+      // result. SPIRV-Cross (as bundled in MoltenVK 1.4.2) translates image /
+      // texel-buffer atomics by appending a `.x` component extraction to the
+      // MSL call, which is valid for value-returning atomics but produces
+      // `atomic_store(...).x` (member access on void) for OpAtomicStore,
+      // failing MSL compilation. Exchange-with-ignored-result is semantically
+      // identical to a store.
+      case ir::AtomicOp::eStore:            return std::make_pair(spv::OpAtomicExchange, 1u);
       case ir::AtomicOp::eExchange:         return std::make_pair(spv::OpAtomicExchange, 1u);
       case ir::AtomicOp::eCompareExchange:  return std::make_pair(spv::OpAtomicCompareExchange, 2u);
       case ir::AtomicOp::eAdd:              return std::make_pair(spv::OpAtomicIAdd, 1u);
@@ -2539,18 +2553,18 @@ void SpirvBuilder::emitAtomic(const ir::Op& op, const ir::Type& type, uint32_t i
   /* Emit atomic instruction */
   uint32_t operandCount = 4u + argCount;
 
-  if (atomicOp != ir::AtomicOp::eStore)
-    operandCount += 2u;  /* result type and id */
+  /* Tea/MoltenVK: stores are emitted as OpAtomicExchange (see above), which
+   * always carries a result type and id; use a fresh id for the discarded
+   * result since the store op's own def is void. */
+  operandCount += 2u;  /* result type and id */
 
