diff --git a/src/dxvk/dxvk_memory.cpp b/src/dxvk/dxvk_memory.cpp
index 69a11600..83da6d45 100644
--- a/src/dxvk/dxvk_memory.cpp
+++ b/src/dxvk/dxvk_memory.cpp
@@ -335,6 +335,14 @@ namespace dxvk {
     auto device = m_allocator->device();
     auto vk = device->vkd();
 
+    // Tea/MoltenVK: VK_KHR_external_memory_win32 is never available on MoltenVK,
+    // so this proc address is null. Upstream assumes Windows drivers always have it
