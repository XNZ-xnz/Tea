diff --git a/src/d3d11/d3d11_query.cpp b/src/d3d11/d3d11_query.cpp
index 440ccaa7..8291f671 100644
--- a/src/d3d11/d3d11_query.cpp
+++ b/src/d3d11/d3d11_query.cpp
@@ -253,8 +253,15 @@ namespace dxvk {
     if (m_desc.Query == D3D11_QUERY_EVENT) {
       DxvkGpuEventStatus status = m_event[0]->test();
 
-      if (status == DxvkGpuEventStatus::Invalid)
-        return DXGI_ERROR_INVALID_CALL;
+      // Tea/MoltenVK tolerance: a broken GPU event would otherwise surface as
+      // a fatal DXGI_ERROR_INVALID_CALL (UE appErrors on it) or, if reported
+      // as unsignaled, make the engine wait forever. Report it as signaled.
+      if (status == DxvkGpuEventStatus::Invalid) {
+        Logger::warn("D3D11Query: GPU event in invalid state, reporting as signaled");
+        if (pData != nullptr)
+          *static_cast<BOOL*>(pData) = TRUE;
+        return S_OK;
+      }
       
       bool signaled = status == DxvkGpuEventStatus::Signaled;
 
@@ -268,10 +275,13 @@ namespace dxvk {
       for (uint32_t i = 0; i < MaxGpuQueries && m_query[i] != nullptr; i++) {
         DxvkGpuQueryStatus status = m_query[i]->getData(queryData[i]);
 
+        // Tea/MoltenVK tolerance: some timestamp/occlusion queries report
+        // Invalid/Failed on MoltenVK; treat as completed-with-zero instead of
+        // a fatal DXGI_ERROR_INVALID_CALL so the engine keeps rendering.
         if (status == DxvkGpuQueryStatus::Invalid
          || status == DxvkGpuQueryStatus::Failed)
-          return DXGI_ERROR_INVALID_CALL;
-        
+          continue;
+
         if (status == DxvkGpuQueryStatus::Pending)
           return S_FALSE;
       }
diff --git a/src/d3d11/d3d11_swapchain.cpp b/src/d3d11/d3d11_swapchain.cpp
index cbcc3c6c..78baf68f 100644
--- a/src/d3d11/d3d11_swapchain.cpp
+++ b/src/d3d11/d3d11_swapchain.cpp
@@ -379,6 +379,40 @@ namespace dxvk {
     auto immediateContext = m_parent->GetContext();
     auto immediateContextLock = immediateContext->LockContext();
 
+    // Tea 验尸: TEA_DUMP_PRESENT=1 时每 300 帧转储游戏交来的 D3D 背缓冲
+    {
+      static int en = -1;
+      static uint32_t n = 0, dumped = 0;
+      if (en < 0) { const char* e = std::getenv("TEA_DUMP_PRESENT"); en = (e && e[0]=='1') ? 1 : 0; }
+      if (en && !m_backBuffers.empty() && (++n % 300u) == 0u && dumped < 4u) {
+        D3D11_TEXTURE2D_DESC td;
+        m_backBuffers[0]->GetDesc(&td);
+        D3D11_TEXTURE2D_DESC sd = td;
+        sd.Usage = D3D11_USAGE_STAGING; sd.BindFlags = 0;
+        sd.CPUAccessFlags = D3D11_CPU_ACCESS_READ; sd.MiscFlags = 0;
+        sd.MipLevels = 1; sd.ArraySize = 1;
+        Com<ID3D11Texture2D> staging;
+        if (SUCCEEDED(m_parent->CreateTexture2D(&sd, nullptr, &staging))) {
+          immediateContext->CopySubresourceRegion(staging.ptr(), 0, 0, 0, 0, m_backBuffers[0].ptr(), 0, nullptr);
+          D3D11_MAPPED_SUBRESOURCE map = { };
+          if (SUCCEEDED(immediateContext->Map(staging.ptr(), 0, D3D11_MAP_READ, 0, &map))) {
+            char path[256];
+            std::snprintf(path, sizeof(path), "Z:\\tmp\\tea-rt-dumps\\present%u_%ux%u_fmt%u.raw",
+              dumped, td.Width, td.Height, uint32_t(td.Format));
+            if (FILE* f = std::fopen(path, "wb")) {
+              for (uint32_t y = 0; y < td.Height; y++)
+                std::fwrite(reinterpret_cast<const char*>(map.pData) + size_t(y) * map.RowPitch, 1, map.RowPitch, f);
+              std::fclose(f);
+              Logger::info(str::format("Tea: present dump ", dumped, " fmt=", uint32_t(td.Format),
+                " ", td.Width, "x", td.Height));
+              dumped++;
+            }
+            immediateContext->Unmap(staging.ptr(), 0);
+          }
+        }
+      }
+    }
+
     immediateContext->EndFrame(m_latency);
     immediateContext->ExecuteFlush(GpuFlushType::ExplicitFlush, nullptr, true);
 
