index 440ccaa..2174d28 100644
--- a/src/d3d11/d3d11_query.cpp
+++ b/src/d3d11/d3d11_query.cpp
@@ -268,10 +268,13 @@ namespace dxvk {
       for (uint32_t i = 0; i < MaxGpuQueries && m_query[i] != nullptr; i++) {
         DxvkGpuQueryStatus status = m_query[i]->getData(queryData[i]);
 
+        // Tea/MoltenVK tolerance: some timestamp/occlusion queries report
+        // Invalid/Failed on MoltenVK; treat as completed-with-zero instead of
+        // a fatal DXGI_ERROR_INVALID_CALL so the engine keeps rendering.
         if (status == DxvkGpuQueryStatus::Invalid
          || status == DxvkGpuQueryStatus::Failed)
-          return DXGI_ERROR_INVALID_CALL;
-        
+          continue;
+
         if (status == DxvkGpuQueryStatus::Pending)
           return S_FALSE;
       }
