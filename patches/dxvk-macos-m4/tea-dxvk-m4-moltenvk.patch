+    // Tea/MoltenVK: VK_KHR_external_semaphore_win32 is never available on MoltenVK,
+    // so this proc address is null. Guard against jumping to address 0 (same crash
+    // class as DxvkResourceAllocation::initKmtHandles).
+    if (!m_vkd->vkGetSemaphoreWin32HandleKHR) {
+      Logger::warn("DxvkFence::initKmtHandles: vkGetSemaphoreWin32HandleKHR not available, skipping");
+      return;
+    }
+
     VkSemaphoreGetWin32HandleInfoKHR win32HandleInfo = { VK_STRUCTURE_TYPE_SEMAPHORE_GET_WIN32_HANDLE_INFO_KHR };
     win32HandleInfo.semaphore = m_semaphore;
     win32HandleInfo.handleType = m_info.sharedType;
