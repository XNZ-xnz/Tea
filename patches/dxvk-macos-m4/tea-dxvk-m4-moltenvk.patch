diff --git a/src/d3d11/d3d11_query.cpp b/src/d3d11/d3d11_query.cpp
index 440ccaa7..8291f671 100644
--- a/src/d3d11/d3d11_query.cpp
+++ b/src/d3d11/d3d11_query.cpp
@@ -253,8 +253,15 @@ namespace dxvk {
     if (m_desc.Query == D3D11_QUERY_EVENT) {
       DxvkGpuEventStatus status = m_event[0]->test();
 
-      if (status == DxvkGpuEventStatus::Invalid)
-        return DXGI_ERROR_INVALID_CALL;
+      // Tea/MoltenVK tolerance: a broken GPU event would otherwise surface as
+      // a fatal DXGI_ERROR_INVALID_CALL (UE appErrors on it) or, if reported
+      // as unsignaled, make the engine wait forever. Report it as signaled.
+      if (status == DxvkGpuEventStatus::Invalid) {
+        Logger::warn("D3D11Query: GPU event in invalid state, reporting as signaled");
+        if (pData != nullptr)
+          *static_cast<BOOL*>(pData) = TRUE;
+        return S_OK;
+      }
       
       bool signaled = status == DxvkGpuEventStatus::Signaled;
 
@@ -268,10 +275,13 @@ namespace dxvk {
       for (uint32_t i = 0; i < MaxGpuQueries && m_query[i] != nullptr; i++) {
         DxvkGpuQueryStatus status = m_query[i]->getData(queryData[i]);
 
+        // Tea/MoltenVK tolerance: some timestamp/occlusion queries report
+        // Invalid/Failed on MoltenVK; treat as completed-with-zero instead of
+        // a fatal DXGI_ERROR_INVALID_CALL so the engine keeps rendering.
         if (status == DxvkGpuQueryStatus::Invalid
          || status == DxvkGpuQueryStatus::Failed)
-          return DXGI_ERROR_INVALID_CALL;
-        
+          continue;
+
         if (status == DxvkGpuQueryStatus::Pending)
           return S_FALSE;
       }
